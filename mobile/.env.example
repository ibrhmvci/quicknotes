# Local development only. For EAS production builds use https:// and set via:
#   eas env:create --name EXPO_PUBLIC_API_URL --value "https://your-backend.railway.app" --environment production
EXPO_PUBLIC_API_URL=http://localhost:5000

# Clerk publishable key — safe to include in client bundle (not a secret)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
