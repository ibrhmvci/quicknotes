# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Clerk keys — get from clerk.com → Configure → API Keys
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook signing secret — get from clerk.com → Configure → Webhooks
CLERK_WEBHOOK_SECRET="whsec_..."

# Server
PORT=5000

# Frontend URL (used for CORS — no trailing slash)
FRONTEND_URL="http://localhost:5173"
